# Viper Server Configuration
PORT=3000
LOG_LEVEL=info

# Webhook secret (shared with your VCS provider)
WEBHOOK_SECRET=your-webhook-secret

# Database path (SQLite)
# DATABASE_PATH=./data/viper.db

# Optional: Bot user ID (prevents self-replies)
# BOT_USER_ID=12345

# -------------------------------------------------------
# Provider config is stored in the database, not env vars.
# On first run, seed settings via the API or SQLite CLI:
#
#   INSERT INTO settings (key, value, is_secret) VALUES
#     ('vcs_provider_type', 'gitlab', 0),
#     ('vcs_url', 'https://gitlab.com', 0),
#     ('vcs_token', 'glpat-xxxxxxxxxxxx', 1),
#     ('ai_provider_type', 'claude', 0),
#     ('ai_api_key', 'sk-ant-xxxxxxxxxxxx', 1);
# -------------------------------------------------------
