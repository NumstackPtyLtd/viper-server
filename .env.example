# Viper Server Configuration
PORT=3000

# Provider selection
VCS_PROVIDER=gitlab           # gitlab (github coming soon)
AI_PROVIDER=claude            # claude (openai coming soon)

# VCS config (provider-agnostic)
VCS_URL=https://gitlab.com
VCS_TOKEN=glpat-xxxxxxxxxxxxxxxxxxxx
WEBHOOK_SECRET=your-webhook-secret

# AI config (provider-agnostic)
AI_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx
# AI_MODEL=claude-sonnet-4-20250514   # Optional: defaults to provider's default model

# Optional
# BOT_USER_ID=12345

# Logging
LOG_LEVEL=info
