# Viper Server — Environment Variables
# Copy to .env and fill in values.
# All have defaults so the server boots without a .env file.

# Server port (default: 3000)
# PORT=3000

# Log level: debug, info, warn, error (default: info)
# LOG_LEVEL=info

# SQLite database path (default: ./data/viper.db)
# DATABASE_PATH=./data/viper.db
