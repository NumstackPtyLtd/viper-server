{
  "name": "viper-server",
  "version": "0.1.0",
  "description": "AI-powered code reviewer — open-source server",
  "type": "module",
  "private": true,
  "exports": {
    "./server": "./src/server.ts"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc --noEmit",
    "start": "node --import tsx src/index.ts",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@hono/node-server": "^1.13.0",
    "hono": "^4.6.0",
    "yaml": "^2.6.0",
    "zod": "^3.24.0",
    "minimatch": "^10.0.0",
    "pino": "^9.5.0"
  },
  "devDependencies": {
    "@types/minimatch": "^5.1.0",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^3.2.1",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.2.1"
  },
  "license": "MIT"
}
